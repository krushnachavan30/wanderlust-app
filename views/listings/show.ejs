<% layout("layouts/boilerplate")%>
<script>
let mapToken="<%= process.env.MAP_TOKEN %>";
let listings= <%-JSON.stringify(listings)%>;

</script>
<div class="row mt-3">
    <div class="col-8 offset-3">
<h3><%=listings.title%></h3>
</div>
<div class="card-listing">

    <div class="card-listing  col-6 offset-3">
        <img src="<%=listings.image.url%>" class="card-img-top show-img" alt="listing_image">
        <div class="card-body">

            <p class="card-text" <i>Owned by: <%= listings.owner.username%></i></p>
            <p class="card-text">
                <%=listings.description%>
            </p>

            <p class="card-text">&#8377; <%= listings.price?.toLocaleString("en-IN") || "Price not available" %>
            </p>
            <p class="card-text">
                <%=listings.location%>
            </p>
            <p class="card-text">
              <%=listings.country%>
            </p>



         </div>
    </div>
    <%if(currUser && currUser._id.equals(listings.owner._id)){%>
    <div class="btns">
        <a href="/listings/<%= listings._id%>/edit" class="btn btn-dark col-1 offset-3 btn-new">EDIT</a>

         <form action="/listings/<%=listings._id%>?_method=DELETE" method="post">
            <button type="submit" class="btn btn-dark offset-5">Delete</button>
        </form>
    </div>

    <%}%>

    <div class="card-listing col-6 offset-3 mb-3">
        <%if(currUser ){%>
            <hr>
            <h3>leave your review here</h3>
            <form action="/listings/<%= listings.id%>/reviews" method="POST" novalidate
                class="needs-validation">
                <!-- <div class="mb-3 mt-3">
                    <label for="rating" class="form-label">Rating</label>
                    <input type="range" class="form-range" min="1" max="5" id="rating"
                    name="review[rating]">

                </div> -->

                <div class="mb-3 mt-3">
                <label for="rating" class="form-label">Rating</label>
                <fieldset class="starability-slot">
               

                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0"
                    checked aria-label="No rating." />
                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                <label for="first-rate1" title="Terrible">1 star</label>
                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                <label for="first-rate2" title="Not good">2 stars</label>
                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                <label for="first-rate3" title="Average">3 stars</label>
                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                <label for="first-rate4" title="Very good">4 stars</label>
                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                <label for="first-rate5" title="Amazing">5 stars</label>
                </fieldset>
                </div>
                <div class="mb-3 mt-3">
                <label for="comment" class="form-label">Comment</label>
                <textarea name="review[comment]" id="comment" class="form-control"
                    required>
                </textarea>
                <div class="invalid-feedback">
                    please add some comments for reviews
                </div>
            </div>
            <button class="btn btn-outline-primary">submit</button>

        </form>
        <%}%>

        <hr>
      
        <div class="row">
            
        <% for(let review of listings.reviews){ %>
  <p><b>All Reveiw</b></p>
        <div class="col-md-6 mb-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title ms-2">@<%= review.author.username%>
                    </h5>
                    <p class="starability-result card-text ms-2" data-rating="<%= review.rating %>">
                     
                    </p>
                    <p class="card-text ms-2">
                            Review: <%= review.comment %>       
                    </p>
                                                   
                    <form method="post"
                        action="/listings/<%= listings._id%>/reviews/<%=review._id%>?_method=DELETE"
                        class="mb-3">
                        <button class="btn btn-sm btn-dark ms-2">Delete</button>
                    </form>
                </div>
            </div>
        </div>

        <% } %>
    </div>
    <div lass="col-8 offset-3 mb-3">
        <h3>where we'll be</h3>
       <div id="map"></div>
    </div>
</div>
</div>

<script src="/js/map.js"></script>